// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// Yahan aapki file mein 'url' wali line miss thi, maine add kar di hai
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String   @unique
  password   String
  role       String   
  rollNumber String   @unique
  secretKey  String   @unique  
  className  String?  
  subject    String?  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
// prisma/schema.prisma ke aakhir mein yeh add karein:

model Message {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  senderEmail   String   // Kisne message bheja
  senderName    String   // Bhejne wale ka naam
  receiverEmail String   // Kisko bheja (Agar group hai toh hum "GROUP" likhenge)
  className     String   // Kis class ka message hai
  text          String   // Message ka text
  createdAt     DateTime @default(now())
}
// prisma/schema.prisma ke aakhir mein add karein:

model ResearchPaper {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  authorEmail String
  authorName  String
  authorRole  String   // Student ya Teacher
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}